{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vex",
  "patterns": [{ "include": "#vex-root" }],
  "repository": {
    "comment": {
      "match": "#[^\\n]*",
      "name": "comment.line.number-sign.vex"
    },
    "function-header": {
      "match": "^([a-zA-Z0-9_/.\\-]+)\\s*:\\s*$",
      "captures": {
        "1": { "name": "entity.name.function.vex" }
      }
    },
    "list-item": {
      "match": "^(\\s*)(-\\s*)(WHEN|AND|IT)(:)(.*)$",
      "captures": {
        "1": { "name": "meta.indent.vex" },
        "2": { "name": "punctuation.definition.list.begin.vex" },
        "3": { "name": "keyword.control.vex" },
        "4": { "name": "punctuation.separator.key-value.vex" },
        "5": { "name": "string.unquoted.description.vex" }
      }
    },
    "vex-root": {
      "patterns": [{ "include": "#comment" }, { "include": "#function-header" }, { "include": "#list-item" }]
    }
  },
  "scopeName": "source.vex"
}

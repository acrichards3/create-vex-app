{
  "name": "@vex-app/mcp-feature-workflow",
  "version": "0.0.0",
  "type": "module",
  "description": "MCP App for the 6-step vexkit feature workflow",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --target=bun src/index.ts --outdir=dist --splitting",
    "bundle": "node ../vexkit/scripts/bundle-dashboard.mjs && cp -r ../vexkit/dist/dashboard/bundle/* ./static/",
    "prebuild": "bun run bundle"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@vex-app/lib": "workspace:*",
    "d3": "^7.9.0",
    "dompurify": "^3.2.6",
    "marked": "^15.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "bun-types": "latest",
    "esbuild": "^0.24.0"
  }
}

{
  "name": "cursor-vex-panel",
  "displayName": "Vex Panel",
  "description": "Vex bottom panel (workflow stepper) and tree view for .vex files in the editor area.",
  "version": "0.0.3",
  "private": true,
  "publisher": "vex-app",
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Other"
  ],
  "main": "extension.js",
  "activationEvents": [
    "onView:vex.panel.stepper",
    "onCommand:vex.panel.openEditorVisual",
    "onCustomEditor:vex.tree"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "vex.tree",
        "displayName": "Vex tree",
        "selector": [
          {
            "filenamePattern": "*.vex"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "vex.panel.openEditorVisual",
        "title": "Open Vex tree (current .vex file)",
        "category": "Vex"
      }
    ],
    "viewsContainers": {
      "panel": [
        {
          "id": "vex-panel",
          "title": "Vex",
          "icon": "media/vex-panel.svg"
        }
      ]
    },
    "views": {
      "vex-panel": [
        {
          "type": "webview",
          "id": "vex.panel.stepper",
          "name": "Workflow"
        }
      ]
    }
  },
  "scripts": {
    "lint": "node --check extension.js && node --check vex-tree-editor-provider.js && node --check vex-parse.js && node --check get-editor-html.js && node --check media/editor-visual.js"
  }
}
